# .env.example for evo-billing-service
# Copy to .env and fill in values — NEVER commit .env to git

RAILS_ENV=development
DATABASE_URL=postgresql://postgres:password@localhost:5432/evo_billing_development
REDIS_URL=redis://localhost:6379/2
SECRET_KEY_BASE=CHANGE_ME_generate_with_rails_secret

# JWT public key from evo-auth Doorkeeper (PEM format, full multi-line)
# Get it from: bundle exec rails runner "puts Doorkeeper::JWT.configuration.secret_key.public_key.to_pem" (in evo-auth)
EVO_AUTH_JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nYOUR_KEY_HERE\n-----END PUBLIC KEY-----"

# Internal S2S secret — shared between evo-billing and evo-auth
# Generate with: openssl rand -hex 32
INTERNAL_API_SECRET=CHANGE_ME_generate_with_openssl

# evo-auth internal URL (Docker network name)
EVO_AUTH_INTERNAL_URL=http://evo-auth:3001

# Asaas (Phase 2 — not needed for Phase 1)
# ASAAS_API_KEY=
# ASAAS_WEBHOOK_SECRET=
# ASAAS_ENV=sandbox
