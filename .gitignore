.env
_evo*

.claude
.claude/
.claude/*
.agents/*
CLAUDE.md

# Sibling repos cloned locally but not registered in .gitmodules. They were
# accidentally tracked as orphan gitlinks before; ignore the dirs so nobody
# re-adds them with `git add`.
evolution-hub
evo-ai-docs/
evo-crm-enterprise/
evo-assistant/


# Agentic OS Template - Downstream Ignore Defaults

# Runtime State (work logs are session-local; private is never committed)
.agentcortex/context/work/*.md
.agentcortex/context/work/*.lock.json
!.agentcortex/context/work/.gitkeep.md
.agentcortex/context/.guard_receipt.json
.agentcortex/context/.guard_receipts/
.agentcortex/context/.guard_locks/
.agentcortex/context/private/
.agent/private/

# Deploy Artifacts
.agentcortex-src/
*.acx-incoming
*.acx-local

# Third-party AI Tool Local State
.openrouter/
.claude-chat/
.cursor/
.antigravity/

# End Agentic OS Template - Downstream Ignore Defaults

# Agent/IDE Tooling (local-only, not committed)
.agent/
.agentcortex/
.agentcortex-manifest
.codex/
.opencode/
codex/
graphify-out/
graphify-out-flow/
internal/

# Post-merge cleanup — untracked directories
logs/
shared/
test-results/
tmp/
tests/e2e/node_modules/

